<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="290dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/panel_bg"
    android:padding="0dp">

    <LinearLayout android:id="@+id/panelHeader"
        android:layout_width="match_parent" android:layout_height="46dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@drawable/panel_header_bg">
        <TextView android:id="@+id/btnBack" android:layout_width="32dp"
            android:layout_height="32dp" android:text="◀" android:textSize="14sp"
            android:textColor="#c4b5fd" android:gravity="center"
            android:background="@android:color/transparent"/>
        <TextView android:id="@+id/tvChatTitle" android:layout_width="0dp"
            android:layout_height="wrap_content" android:text="AI 助手"
            android:textSize="15sp" android:textStyle="bold"
            android:textColor="#e0e7ff" android:layout_weight="1" android:gravity="center"/>
        <TextView android:id="@+id/btnMinimize" android:layout_width="32dp"
            android:layout_height="32dp" android:text="−" android:textSize="18sp"
            android:textColor="#c4b5fd" android:gravity="center"
            android:background="@android:color/transparent"/>
        <TextView android:id="@+id/btnClose" android:layout_width="32dp"
            android:layout_height="32dp" android:text="✕" android:textSize="14sp"
            android:textColor="#6366f1" android:gravity="center"
            android:background="@android:color/transparent"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/panelBody"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

    <ScrollView android:id="@+id/scrollOutput"
        android:layout_width="match_parent" android:layout_height="180dp"
        android:background="#00000000" android:padding="8dp">
        <TextView android:id="@+id/tvOutput" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="10dp"
            android:textSize="13sp" android:textColor="#c4b5fd"
            android:lineSpacingExtra="4dp"
            android:background="@drawable/input_bg"
            android:text="选择岗位后开始AI对话"/>
    </ScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp">
        <TextView android:id="@+id/btnGreet" android:layout_width="0dp"
            android:layout_height="38dp" android:text="👋 招呼" android:gravity="center"
            android:layout_weight="1" android:layout_marginEnd="3dp"
            android:textSize="11sp" android:textColor="#c4b5fd"
            android:background="@drawable/btn_secondary"/>
        <TextView android:id="@+id/btnRegen" android:layout_width="0dp"
            android:layout_height="38dp" android:text="🔄 重生" android:gravity="center"
            android:layout_weight="1" android:layout_marginEnd="3dp"
            android:textSize="11sp" android:textColor="#c4b5fd"
            android:background="@drawable/btn_secondary"/>
        <TextView android:id="@+id/btnCopy" android:layout_width="0dp"
            android:layout_height="38dp" android:text="📋 复制" android:gravity="center"
            android:layout_weight="1" android:layout_marginEnd="3dp"
            android:textSize="11sp" android:textColor="#c4b5fd"
            android:background="@drawable/btn_secondary"/>
        <TextView android:id="@+id/btnFill" android:layout_width="0dp"
            android:layout_height="38dp" android:text="📤 填入" android:gravity="center"
            android:layout_weight="1"
            android:textSize="11sp" android:textColor="#a78bfa"
            android:background="@drawable/btn_secondary"/>
    </LinearLayout>

    <!-- 可折叠输入框 -->
    <LinearLayout android:id="@+id/inputArea" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:paddingHorizontal="8dp" android:paddingBottom="4dp"
        android:visibility="gone">
        <EditText android:id="@+id/etInput" android:layout_width="match_parent"
            android:layout_height="42dp" android:hint="输入消息..."
            android:textColorHint="#6366f1" android:textColor="#e0e7ff"
            android:textSize="13sp" android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="8dp"
        android:paddingBottom="10dp">
        <TextView android:id="@+id/btnInputToggle" android:layout_width="wrap_content"
            android:layout_height="42dp" android:text="⌨️" android:gravity="center"
            android:paddingHorizontal="10dp"
            android:textSize="16sp" android:textColor="#c4b5fd"
            android:background="@drawable/btn_secondary" android:layout_marginEnd="4dp"/>
        <TextView android:id="@+id/btnPaste" android:layout_width="0dp"
            android:layout_height="42dp" android:text="📋 粘贴" android:gravity="center"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:textSize="12sp" android:textColor="#c4b5fd"
            android:background="@drawable/btn_secondary"/>
        <TextView android:id="@+id/btnSend" android:layout_width="0dp"
            android:layout_height="42dp" android:text="🤖 发送" android:gravity="center"
            android:layout_weight="1"
            android:textSize="12sp" android:textColor="#fff"
            android:background="@drawable/btn_primary"/>
    </LinearLayout>

    </LinearLayout>

</LinearLayout>
